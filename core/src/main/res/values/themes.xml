<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Storeez" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/B500</item>
        <item name="colorPrimaryVariant">@color/B600</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/B500</item>
        <item name="colorSecondaryVariant">@color/B600</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="android:homeAsUpIndicator">@drawable/ic_back</item>
    </style>

    <style name="Theme.Storeez.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Storeez.NoActionBar.DarkStatusBarIcon">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Storeez.Default">
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Storeez.Regular">
        <item name="android:fontFamily">@font/noto_sans</item>
    </style>

    <style name="Theme.Storeez.Medium">
        <item name="android:fontFamily">@font/noto_sans_medium</item>
    </style>

    <style name="Theme.Storeez.SemiBold">
        <item name="android:fontFamily">@font/noto_sans_semi_bold</item>
    </style>

    <style name="Theme.Storeez.Bold">
        <item name="android:fontFamily">@font/noto_sans_bold</item>
    </style>
</resources>